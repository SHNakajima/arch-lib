/* ═══════════════════════════════════════════════════════
   CATALOG — Company Card Grid & Hero Section
   ═══════════════════════════════════════════════════════ */

/* ── Hero Section ── */
.hero {
  position: relative;
  padding: var(--space-20) var(--space-8) var(--space-16);
  text-align: center;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 0%, hsla(190, 90%, 55%, 0.08) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 80% 100%, hsla(265, 80%, 65%, 0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 10% 60%, hsla(38, 95%, 60%, 0.04) 0%, transparent 60%);
  pointer-events: none;
}

.hero__title {
  font-size: var(--text-5xl);
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-4);
  animation: fadeInUp 0.8s var(--ease-out);
}

.hero__subtitle {
  font-size: var(--text-lg);
  color: var(--text-secondary);
  max-width: 640px;
  margin: 0 auto var(--space-10);
  line-height: var(--leading-relaxed);
  animation: fadeInUp 0.8s var(--ease-out) 0.1s both;
}

.hero__stats {
  display: flex;
  justify-content: center;
  gap: var(--space-10);
  animation: fadeInUp 0.8s var(--ease-out) 0.2s both;
}

.hero__stat {
  text-align: center;
}

.hero__stat-value {
  font-size: var(--text-3xl);
  font-weight: 700;
  font-family: var(--font-mono);
}

.hero__stat-label {
  font-size: var(--text-sm);
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-top: var(--space-1);
}

/* ── Filter Bar ── */
.filter-bar {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-8);
  flex-wrap: wrap;
  animation: fadeInUp 0.8s var(--ease-out) 0.3s both;
}

.filter-bar__search {
  flex: 1;
  min-width: 240px;
  position: relative;
}

.filter-bar__search-icon {
  position: absolute;
  left: var(--space-4);
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-tertiary);
  pointer-events: none;
  width: 18px;
  height: 18px;
}

.filter-bar__input {
  width: 100%;
  padding: var(--space-3) var(--space-4) var(--space-3) var(--space-12);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--text-primary);
  background: var(--bg-secondary);
  border: 1px solid var(--bg-glass-border);
  border-radius: var(--radius-full);
  outline: none;
  transition: border-color var(--duration-fast) var(--ease-out),
              box-shadow var(--duration-fast) var(--ease-out);
}

.filter-bar__input::placeholder {
  color: var(--text-tertiary);
}

.filter-bar__input:focus {
  border-color: var(--accent-cyan);
  box-shadow: 0 0 0 3px hsla(190, 90%, 55%, 0.15);
}

.filter-bar__tags {
  display: flex;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.filter-tag {
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--bg-secondary);
  border: 1px solid var(--bg-glass-border);
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  text-transform: capitalize;
  white-space: nowrap;
}

.filter-tag:hover {
  color: var(--text-primary);
  border-color: var(--accent-cyan);
  background: hsla(190, 90%, 55%, 0.08);
}

.filter-tag--active {
  color: var(--bg-primary);
  background: var(--accent-cyan);
  border-color: var(--accent-cyan);
}

.filter-tag--active:hover {
  color: var(--bg-primary);
  background: var(--accent-violet);
  border-color: var(--accent-violet);
}

/* ── Card Grid ── */
.catalog-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: var(--space-6);
  padding: var(--space-6) var(--space-8) var(--space-16);
}

.catalog-card {
  position: relative;
  background: var(--bg-secondary);
  border: 1px solid var(--bg-glass-border);
  border-radius: var(--radius-lg);
  padding: var(--space-6);
  cursor: pointer;
  transition: all var(--duration-normal) var(--ease-out);
  overflow: hidden;
  animation: fadeInUp 0.6s var(--ease-out) both;
  content-visibility: auto;
  contain-intrinsic-size: 0 220px;
}

.catalog-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--card-accent, var(--accent-gradient));
  opacity: 0;
  transition: opacity var(--duration-normal) var(--ease-out);
}

.catalog-card:hover {
  transform: translateY(-4px);
  border-color: hsla(190, 60%, 50%, 0.3);
  box-shadow: var(--shadow-lg), var(--shadow-glow-cyan);
}

.catalog-card:hover::before {
  opacity: 1;
}

.catalog-card__header {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-4);
}

.catalog-card__icon {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-2xl);
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.catalog-card__title {
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: -0.01em;
}

.catalog-card__category {
  font-size: var(--text-xs);
  color: var(--text-tertiary);
  margin-top: var(--space-1);
}

.catalog-card__description {
  font-size: var(--text-sm);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
  margin-bottom: var(--space-5);
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.catalog-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.catalog-card__tag {
  padding: var(--space-1) var(--space-3);
  font-size: var(--text-xs);
  font-family: var(--font-mono);
  color: var(--text-tertiary);
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
}

.catalog-card__arrow {
  position: absolute;
  bottom: var(--space-6);
  right: var(--space-6);
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  background: var(--bg-tertiary);
  border-radius: var(--radius-full);
  transition: all var(--duration-normal) var(--ease-out);
}

.catalog-card:hover .catalog-card__arrow {
  color: var(--text-primary);
  background: var(--accent-cyan);
  transform: translateX(4px);
}

/* ── Empty State ── */
.catalog-empty {
  grid-column: 1 / -1;
  text-align: center;
  padding: var(--space-20) var(--space-8);
}

.catalog-empty__icon {
  font-size: 3rem;
  margin-bottom: var(--space-4);
}

.catalog-empty__message {
  font-size: var(--text-lg);
  color: var(--text-secondary);
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .hero {
    padding: var(--space-12) var(--space-4) var(--space-10);
  }

  .hero__title {
    font-size: var(--text-3xl);
  }

  .hero__subtitle {
    font-size: var(--text-base);
  }

  .hero__stats {
    gap: var(--space-6);
  }

  .hero__stat-value {
    font-size: var(--text-2xl);
  }

  .filter-bar {
    padding: var(--space-3) var(--space-4);
  }

  .catalog-grid {
    grid-template-columns: 1fr;
    padding: var(--space-4);
  }
}
