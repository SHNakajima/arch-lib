.scenario-step__text {
  font-size: var(--text-xs);
  color: var(--text-secondary);
  line-height: var(--leading-relaxed);
  padding-top: 2px;
}

/* ── Legend ── */
.diagram-legend {
  position: absolute;
  top: var(--space-4);
  right: var(--space-4);
  z-index: var(--z-ui);
  padding: var(--space-3) var(--space-4);
  border-radius: var(--radius-md);
}

.diagram-legend__title {
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-tertiary);
  margin-bottom: var(--space-2);
}

.diagram-legend__items {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.diagram-legend__item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: var(--text-secondary);
}

.diagram-legend__dot {
  width: 10px;
  height: 10px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .diagram-toolbar {
    padding: var(--space-2) var(--space-3);
    flex-wrap: wrap;
  }

  .diagram-toolbar__title {
    font-size: var(--text-base);
  }

  .scenario-bar {
    padding: var(--space-2) var(--space-3);
  }

  .scenario-info,
  .scenario-steps {
    position: static;
    max-width: none;
  }

  .diagram-legend {
    display: none;
  }
}
